# API do backend NestJS (padrão: http://localhost:3000)
VITE_API_BASE_URL=http://localhost:3000

# Supabase Auth (obrigatório para login/cadastro)
# Obtenha em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Google Maps (opcional, para mapa de criadores)
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=

# Sentry (opcional) — DSN é público no cliente; use toggle para desligar
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_VERCEL_GIT_COMMIT_SHA=
